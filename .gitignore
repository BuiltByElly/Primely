# =========================
# General .gitignore for Primely Monorepo
# Covers: Backend (Python) & Frontend (TanStack Start + Bun)
# =========================

# --- Python / Backend ---
__pycache__/
*.py[cod]
*wheels/
*.egg-info/
.venv/


# --- TanStack Start / Frontend (Bun) ---
node_modules/
dist/
.output/
build/

# --- OS generated files ---
.DS_Store
Thumbs.db

# --- Editor directories and files ---
.vscode/
.idea/
.zed/
*.swp
*.swo

# --- Logs ---
app_dev.log

# --- General env files at root ---
.env
postman/
.postman/

notes.txt
Frontend/public/manifest.json
